#!/usr/bin/env python3
"""AI Governor CLI — Direct command execution without Telegram bridge.

Usage:
    governor <command> [action] [args] [flags]
    governor --help
    governor --version
"""
import os
import sys

# KOAN_ROOT must be set before any app.* import
os.environ.setdefault("KOAN_ROOT", os.path.dirname(os.path.abspath(__file__)))

# Add koan/ to sys.path so 'from app.*' imports work
koan_dir = os.path.join(os.environ["KOAN_ROOT"], "koan")
if koan_dir not in sys.path:
    sys.path.insert(0, koan_dir)

from app.utils import load_dotenv
load_dotenv()

from app.governor_cli import main
sys.exit(main())
